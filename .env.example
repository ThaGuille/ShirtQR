# --- Supabase (Project Settings -> API) ---
# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER prefix with NEXT_PUBLIC. Used for admin deletes.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin controller ---
# The single password that unlocks /admin. Make it long.
ADMIN_PASSWORD=

# --- Site URL (optional) ---
# Your public origin, used to generate the shirt's QR code (e.g.
# https://your-app.vercel.app). If unset, /admin falls back to the request host.
NEXT_PUBLIC_SITE_URL=
